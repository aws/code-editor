Index: code-editor-src/extensions/post-startup-notifications/esbuild.mts
===================================================================
--- /dev/null
+++ code-editor-src/extensions/post-startup-notifications/esbuild.mts
@@ -0,0 +1,14 @@
+import * as path from 'node:path';
+import { run } from '../esbuild-extension-common.mts';
+
+const srcDir = path.join(import.meta.dirname, 'src');
+const outDir = path.join(import.meta.dirname, 'dist');
+
+run({
+	platform: 'node',
+	entryPoints: {
+		'extension': path.join(srcDir, 'extension.ts'),
+	},
+	srcDir,
+	outdir: outDir,
+}, process.argv);
